<header>
  <h2>{{title}}</h2>
</header>

<section class="card">
  <form>
    <label for="user">{{form.usernameLabel}}</label>
    <input
      id="user"
      type="text"
      placeholder="{{form.usernamePlaceholder}}"
    >

    <label for="mail">{{form.emailLabel}}</label>
    <input
      id="mail"
      type="email"
      placeholder="{{form.emailPlaceholder}}"
    >

    <label for="p1">{{form.pw1Label}}</label>
    <input
      id="p1"
      type="password"
      placeholder="{{form.pw1Placeholder}}"
    >

    <label for="p2">{{form.pw2Label}}</label>
    <input
      id="p2"
      type="password"
      placeholder="{{form.pw2Placeholder}}"
    >

    <div class="row" style="margin-top:12px">
      <button class="btn primary" formaction="{{form.submitTarget}}">
        {{form.submitText}}
      </button>
      <a class="btn right" href="{{form.backHref}}">
        {{form.backText}}
      </a>
    </div>
  </form>
</section>
