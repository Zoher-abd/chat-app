<section class="card">
  <h2>Willkommen zurück, <b>{{user.name}}</b> 👋</h2>
  <p>
    Hier findest du deine aktuellen Chat-Aktivitäten
    und schnellen Zugriff auf alle Räume.
  </p>
</section>

<section class="card">
  <h2>Statistiken</h2>
  <ul>
    {{#stats}}
      <li>{{label}}: <b>{{value}}</b></li>
    {{/stats}}
  </ul>
</section>

<section class="card">
  <h2>Schnellzugriff</h2>
  <div class="row">
    {{#shortcuts}}
      <a
        class="btn {{#primary}}primary{{/primary}}"
        href="{{href}}"
      >
        {{text}}
      </a>
    {{/shortcuts}}
  </div>
</section>

<section class="card">
  <h2>Neuigkeiten</h2>
  <p>
    {{#news}}
      {{.}}<br>
    {{/news}}
  </p>
</section>
