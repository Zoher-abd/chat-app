<section class="card">
  <h2>{{title}}</h2>

  <form>
    <label for="email">{{form.emailLabel}}</label>
    <input
      id="email"
      type="text"
      placeholder="{{form.emailPlaceholder}}"
    >

    <label for="pw">{{form.passwordLabel}}</label>
    <input
      id="pw"
      type="password"
      placeholder="{{form.passwordPlaceholder}}"
    >

    <div class="row" style="margin-top:12px">
      <button class="btn primary" formaction="{{form.loginTarget}}">
        {{form.loginText}}
      </button>
    </div>
  </form>
</section>

<section class="card">
  <div class="row">
    <span>{{register.text}}</span>
    <a class="btn link right" href="{{register.linkHref}}">
      {{register.linkText}}
    </a>
  </div>
</section>
