<header class="row">
  <h2>Room umbenennen</h2>
  <a class="btn right" href="{{base}}/rooms">Zurück</a>
</header>

<section class="card">
  <form method="post" action="{{base}}/room/{{room.id}}/edit">
    <label for="name">Name</label>
    <input id="name" name="name" type="text" value="{{room.name}}" required>

    <div class="row" style="margin-top:12px">
      <button class="btn primary" type="submit">Speichern</button>
    </div>
  </form>
</section>
