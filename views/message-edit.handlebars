<header class="row">
  <h2>Nachricht bearbeiten</h2>
  <a class="btn right" href="{{base}}/chat?roomId={{roomId}}">Zurück</a>
</header>

<section class="card">
  <form action="{{base}}/message/{{message.id}}/edit" method="post">
    <input type="hidden" name="roomId" value="{{roomId}}">

    <label for="text">Text</label>
    <input id="text" name="text" type="text" value="{{message.text}}" required>

    <div class="row" style="margin-top:12px">
      <button class="btn primary" type="submit">Speichern</button>
    </div>
  </form>
</section>
